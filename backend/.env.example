# =============================================================================
# Prior Authorization Review — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file configures the FastAPI orchestrator only.
# The .env file is gitignored and must not be committed with real keys.
# =============================================================================

# ---------------------------------------------------------------------------
# Runtime mode
# ---------------------------------------------------------------------------
# demo   = deterministic output, no API key required. Best for presentations.
# llm    = local/API LLM mode through an OpenAI-compatible chat endpoint.
# hosted = Azure/Foundry hosted agents.
# auto   = backwards-compatible mode using DEMO_MODE / LOCAL_LLM_MODE.
RUNTIME_MODE=auto
DEMO_MODE=true
LOCAL_LLM_MODE=false

# ---------------------------------------------------------------------------
# LLM mode
# ---------------------------------------------------------------------------
# For the standard OpenAI API, use:
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-4.1-mini
#
# For OpenAI-compatible providers, set the provider base URL and model.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2

# When false, LLM/API failures return a visible error instead of silently
# falling back to demo output. Set true only for resilient demos.
LLM_FALLBACK_TO_DEMO=false

# ---------------------------------------------------------------------------
# Hosted agent — Docker Compose local dev
# ---------------------------------------------------------------------------
# In docker-compose.yml these are already hardcoded to Docker service names;
# no action needed for local docker-compose up.
#
# Uncomment to override, e.g. when running the backend process directly
# outside Docker while agents are running inside docker-compose:
# HOSTED_AGENT_CLINICAL_URL=http://localhost:8001
# HOSTED_AGENT_COVERAGE_URL=http://localhost:8002
# HOSTED_AGENT_COMPLIANCE_URL=http://localhost:8003
# HOSTED_AGENT_SYNTHESIS_URL=http://localhost:8004
# HOSTED_AGENT_TIMEOUT_SECONDS=180

# ---------------------------------------------------------------------------
# Foundry Hosted Agents mode
# ---------------------------------------------------------------------------
# For Azure deployment (azd up), these are injected automatically by Bicep.
# Set manually only when testing locally against a Foundry project.
# AZURE_AI_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>
# HOSTED_AGENT_CLINICAL_NAME=clinical-reviewer-agent
# HOSTED_AGENT_COVERAGE_NAME=coverage-assessment-agent
# HOSTED_AGENT_COMPLIANCE_NAME=compliance-agent
# HOSTED_AGENT_SYNTHESIS_NAME=synthesis-agent

# ---------------------------------------------------------------------------
# Frontend CORS origin
# ---------------------------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Azure Application Insights optional tracing
# ---------------------------------------------------------------------------
# APPLICATION_INSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...;LiveEndpoint=...

# Logging level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# OpenTelemetry sensitive-data capture
# ---------------------------------------------------------------------------
# This solution processes patient and clinical information. Leave false unless
# debugging locally with synthetic data.
ENABLE_OTEL_SENSITIVE_DATA=false