# =============================================================================
# Healthcare-2.0 — Local Environment Variables
# =============================================================================
# Copy this file to .env in the repository root:
#   cp .env.example .env
#
# The .env file is gitignored and must never be committed.
# =============================================================================

# ---------------------------------------------------------------------------
# Local run mode
# ---------------------------------------------------------------------------
# Default demo mode uses deterministic outputs and does NOT call an LLM.
# To use your OpenAI API key, set DEMO_MODE=false and LOCAL_LLM_MODE=true.
DEMO_MODE=true
LOCAL_LLM_MODE=false

# ---------------------------------------------------------------------------
# OpenAI API mode
# ---------------------------------------------------------------------------
# Fill this in only in your local .env file, never in GitHub.
OPENAI_API_KEY=your_openai_api_key_here

# Recommended starter model for local development. You can change this to any
# model your OpenAI account has access to.
OPENAI_MODEL=gpt-4.1-mini

# Leave blank for the official OpenAI API. Only set this for compatible gateways.
OPENAI_BASE_URL=

# Optional generation setting.
LLM_TEMPERATURE=0.2

# ---------------------------------------------------------------------------
# Optional generic OpenAI-compatible provider mode
# ---------------------------------------------------------------------------
# These remain supported for OpenRouter, Groq, Together, Nebius, LM Studio,
# Ollama OpenAI bridge, etc. If both OPENAI_* and LLM_* are set, LLM_* wins.
# LLM_API_KEY=
# LLM_MODEL=
# LLM_BASE_URL=

# ---------------------------------------------------------------------------
# Optional Azure / hosted-agent mode
# ---------------------------------------------------------------------------
# Only needed if you run with DEMO_MODE=false and LOCAL_LLM_MODE=false.
# AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry-resource-name>.services.ai.azure.com/api/projects/<project>
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.4

# ---------------------------------------------------------------------------
# Optional MCP and observability settings
# ---------------------------------------------------------------------------
# MCP_ICD10_CODES=https://hcls.mcp.claude.com/icd10_codes/mcp
# MCP_PUBMED=https://pubmed.mcp.claude.com/mcp
# MCP_CLINICAL_TRIALS=https://hcls.mcp.claude.com/clinical_trials/mcp
# MCP_NPI_REGISTRY=https://hcls.mcp.claude.com/npi_registry/mcp
# MCP_CMS_COVERAGE=https://hcls.mcp.claude.com/cms_coverage/mcp
# APPLICATION_INSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
# ENABLE_OTEL_SENSITIVE_DATA=false
